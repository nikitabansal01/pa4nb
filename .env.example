# PA for NB — local development
# Copy to .env:  cp .env.example .env

# Optional: smarter voice-dump parsing (OpenAI GPT-4o-mini)
OPENAI_API_KEY=sk-your-key-here

# Local dev server port (Vercel sets PORT automatically)
PORT=5001

# Required for sign-in when self-hosting (use a long random string in production)
JWT_SECRET=change-this-to-a-long-random-string

# ---------------------------------------------------------------------------
# NOT USED — do not add these (this app does not use Clerk)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# VITE_CLERK_PUBLISHABLE_KEY=
#
# Auth is built-in JWT + bcrypt (server/auth.js), not Clerk.
# Adding Clerk keys in Vercel will not enable auth and may show
# "No environment variables were created" if pasted from Clerk's bulk import.

# ---------------------------------------------------------------------------
# Vercel dashboard — add these manually (Settings → Environment Variables)
# ---------------------------------------------------------------------------
# Name: OPENAI_API_KEY   Value: sk-...     Environments: Production, Preview (optional)
# Name: JWT_SECRET       Value: <random>   Environments: Production only (optional on Vercel; see README)

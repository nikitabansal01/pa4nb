# PA for NB — local development
# Copy to .env:  cp .env.example .env

# Optional: smarter voice-dump parsing (OpenAI GPT-4o-mini)
OPENAI_API_KEY=sk-your-key-here

# Local dev server port (Vercel sets PORT automatically)
PORT=5001

# Clerk (required for sign-in) — from https://dashboard.clerk.com → API keys
CLERK_SECRET_KEY=sk_test_...

# ---------------------------------------------------------------------------
# Client (Vite) — copy to client/.env.local
# ---------------------------------------------------------------------------
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
#
# Vercel + Clerk integration usually sets NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY;
# Vite is configured to read that name too.

# ---------------------------------------------------------------------------
# Vercel cloud save for job applications (optional on Vercel; local uses data/)
# ---------------------------------------------------------------------------
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

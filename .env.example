# PA for NB — local development
# Copy to .env:  cp .env.example .env

# Optional: smarter voice-dump parsing, mock interview AI, and Whisper voice-to-text
# (required for microphone transcription on localhost and production)
OPENAI_API_KEY=sk-your-key-here

# Local dev server port (Vercel sets PORT automatically)
PORT=5001

# Clerk (required for sign-in) — from https://dashboard.clerk.com → API keys
CLERK_SECRET_KEY=sk_test_...

# Google Calendar (read-only) — from Google Cloud Console OAuth client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5001/api/google/callback
CLIENT_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Client — copy to client/.env.local for local sign-in UI
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# (Same name Vercel + Clerk integration set automatically in production.)
# Neon Postgres (optional locally; required on Vercel for signed-in cloud save)
# DATABASE_URL=postgresql://...

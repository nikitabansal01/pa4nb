# Paste into Vercel ONE variable at a time (Settings → Environment Variables → Add).
#
# Format for bulk import (if you use it): exactly KEY=value per line, no quotes, no blank keys.

OPENAI_API_KEY=sk-replace-with-your-openai-key

# Clerk — usually added automatically when you connect Clerk in Vercel Integrations.
# If missing, copy from Clerk Dashboard → API keys.
CLERK_SECRET_KEY=sk_live_or_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_or_test_...

# Optional: cloud save for signed-in job applications on Vercel (Storage → KV).
KV_REST_API_URL=
KV_REST_API_TOKEN=
